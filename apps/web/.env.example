# =============================================================================
# LearnSphere – Umgebungsvariablen
#
# Lokal:      Kopie als apps/web/.env
# Produktion: Kopie als apps/web/.env.production (siehe docs/DEPLOY-*.md)
#
# Validiert werden die Variablen beim Serverstart in src/lib/env.ts –
# fehlt eine Pflicht-Variable, startet der Server gar nicht erst.
# =============================================================================


# -----------------------------------------------------------------------------
# PFLICHT
# -----------------------------------------------------------------------------

# MySQL-Verbindung. Lokal: XAMPP.
# Im Docker-Betrieb wird dieser Wert von docker-compose.yml überschrieben
# (Host heißt dort "db") – er kann also so stehen bleiben.
DATABASE_URL="mysql://root:@localhost:3306/elearning"

# Verschlüsselt die Login-Sessions. In Produktion zwingend erforderlich,
# der Server startet sonst nicht. Erzeugen mit:
#   openssl rand -base64 32
AUTH_SECRET=""

# Hinter einem Reverse-Proxy (Caddy/nginx) nötig, damit Auth.js dem
# weitergereichten Host-Header vertraut.
AUTH_TRUST_HOST=true

# Kanonische Basis-URL – geht in Sitemap, Open Graph, Mail-Links und Embeds.
# Produktion: https://learnsphere.one  (ohne Slash am Ende)
NEXT_PUBLIC_APP_URL="http://localhost:3000"


# -----------------------------------------------------------------------------
# E-MAIL – in Produktion praktisch Pflicht
#
# Ohne Mailversand können sich Nutzer nicht registrieren (Double-Opt-in),
# ihr Passwort nicht zurücksetzen und bekommen keine Wartelisten-Mails.
# Ist nichts konfiguriert, landen Mails nur im Server-Log.
# -----------------------------------------------------------------------------

# Bevorzugter Weg: Resend (https://resend.com) – Domain verifizieren
# (SPF/DKIM), API-Key erstellen, fertig.
RESEND_API_KEY=""

# Absender-Vorlage: XXX wird je Mail-Art ersetzt (noreply, hello,
# newsletter, billing, ...)
RESEND_FROM="LearnSphere <XXX@learnsphere.one>"

# ⚠️ NUR FÜR TESTS – IN PRODUKTION LEER LASSEN!
# Ist hier eine Adresse eingetragen, gehen ALLE Mails an diese eine Adresse
# statt an die echten Empfänger (der Betreff trägt dann "[an: original@…]").
# Praktisch beim Entwickeln, fatal im Livebetrieb.
RESEND_OVERRIDE_TO=""

# Fallback: klassisches SMTP. Wird nur genutzt, wenn RESEND_API_KEY leer ist.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="LearnSphere <no-reply@localhost>"


# -----------------------------------------------------------------------------
# ZAHLUNGEN (Stripe)
#
# Leer = Demo-Checkout ohne echte Zahlung. In Produktion ist der
# Demo-Modus für Bezahlkurse serverseitig gesperrt.
# -----------------------------------------------------------------------------

STRIPE_SECRET_KEY=""
# Aus dem Webhook-Endpunkt im Stripe-Dashboard:
#   URL:    https://learnsphere.one/api/webhooks/stripe
#   Wichtig: "Events von verbundenen Konten" aktivieren (Stripe Connect)
STRIPE_WEBHOOK_SECRET=""


# -----------------------------------------------------------------------------
# KI-FUNKTIONEN (alle optional – ohne Key fällt das Feature sicher zurück)
# -----------------------------------------------------------------------------

# OpenAI: automatische Transkription (Whisper/Diarization) inkl. Untertitel
# und Karaoke-Ansicht, dazu die Inhaltsprüfung von Uploads (Moderation API,
# kostenlos). Leer = kein Auto-Transkript, keine automatische Prüfung.
OPENAI_API_KEY=""

# Claude: bewertet Freitext-Prüfungsantworten sinngemäß, übersetzt
# Transkripte DE ↔ EN und prüft Bilder auf Hass-Symbolik.
# Leer = Freitext wird exakt verglichen, kein Übersetzen.
ANTHROPIC_API_KEY=""

# Optionale Modell-Overrides. LEER LASSEN heißt "Standard verwenden"
# (claude-haiku-4-5-20251001) – ein leerer Wert ist ausdrücklich erlaubt.
AI_GRADING_MODEL=""
AI_TRANSLATE_MODEL=""
AI_MODERATION_MODEL=""


# -----------------------------------------------------------------------------
# LOGIN ÜBER GOOGLE / LINKEDIN (optional)
#
# Die Buttons sind immer sichtbar; die Flows funktionieren, sobald hier
# Zugangsdaten stehen. Namen folgen der Auth.js-Konvention.
# -----------------------------------------------------------------------------

# https://console.cloud.google.com/apis/credentials
#   Redirect-URI: https://learnsphere.one/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# https://developer.linkedin.com/ (Produkt "Sign In with LinkedIn")
#   Redirect-URI: https://learnsphere.one/api/auth/callback/linkedin
AUTH_LINKEDIN_ID=""
AUTH_LINKEDIN_SECRET=""


# -----------------------------------------------------------------------------
# WEITERE INTEGRATIONEN (optional)
# -----------------------------------------------------------------------------

# YouTube Data API: zuverlässige Videodauern für YouTube-Blöcke.
# Ohne Key greift ein Fallback über die YouTube-Watch-Seite.
YOUTUBE_API_KEY=""

# termine.lol-Connect ("Mit termine.lol verbinden" in den Einstellungen):
# Partner-App-Zugangsdaten – müssen bei termine.lol in CONNECT_PARTNERS
# registriert sein, mit redirectUri = NEXT_PUBLIC_APP_URL +
# /api/booking/connect/callback. Leer = Verbinden-Button liefert 503.
TERMINE_CLIENT_ID=""
TERMINE_CLIENT_SECRET=""
# Leer = Produktion (https://termine.lol); für lokale End-zu-End-Tests
# z. B. http://localhost:3000 (dann LearnSphere auf anderem Port starten)
NEXT_PUBLIC_TERMINE_BASE_URL=""


# -----------------------------------------------------------------------------
# BETRIEB & MONITORING (optional)
# -----------------------------------------------------------------------------

# Verteiltes Rate-Limiting via Upstash Redis (https://upstash.com, Free-Tier).
# Leer = In-Memory-Zähler. Das genügt bei EINER Server-Instanz (Standard
# beim Self-Hosting); erst ab mehreren Instanzen/Serverless braucht es
# Redis, weil sonst jede Instanz ihren eigenen Zähler führt.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Fehler-Monitoring via Sentry (https://sentry.io, Free-Tier 5k Fehler/Monat).
# Leer = kein Monitoring. SENTRY_DSN = Server, NEXT_PUBLIC_… = Browser.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Google Analytics 4 (Mess-ID "G-XXXXXXX"). Wird NUR nach Cookie-Einwilligung
# geladen (Consent-Banner); leer = kein Analytics.
NEXT_PUBLIC_GA_ID=""


# -----------------------------------------------------------------------------
# SELF-HOSTING / DOCKER (siehe docs/DEPLOY-HOSTINGER.md)
# -----------------------------------------------------------------------------

# Ablage der Uploads; leer = im Projekt (Dev). Im Docker-Image zeigen die
# Variablen auf persistente Volumes (/data/uploads, /data/uploads-protected)
# und werden dort automatisch gesetzt.
UPLOADS_DIR=""
PROTECTED_UPLOADS_DIR=""

# Superadmin-Anlage (scripts/create-superadmin.mjs). Beide Werte lassen sich
# auch als Argumente übergeben – das ist sauberer, weil dann kein Passwort
# in einer Datei steht:
#   docker compose exec web node scripts/create-superadmin.mjs "mail@domain" "passwort"
# SUPERADMIN_EMAIL=""
# SUPERADMIN_PASSWORD=""


# -----------------------------------------------------------------------------
# MOBILE-APP (Expo) – nur nötig, wenn die native App betrieben wird
# -----------------------------------------------------------------------------

# Signatur der Access-JWTs der App (getrennt vom Web-AUTH_SECRET):
#   openssl rand -base64 32
MOBILE_JWT_SECRET=""

# Signierte Video-URLs; ohne eigenen Wert wird MOBILE_JWT_SECRET verwendet.
MEDIA_SIGN_SECRET=""

# --- In-App-Käufe (Preis-Tier-Produkte, siehe @elearning/core/iap-tiers) ---
# Store-Provision in Prozent: 15 (Small Business Program) oder 30
IAP_STORE_COMMISSION_PERCENT="15"

# Apple: StoreKit-2-Verifikation + Server Notifications V2
APPLE_IAP_BUNDLE_ID="de.learnsphere.app"
APPLE_IAP_ENVIRONMENT="Sandbox"
# Verzeichnis mit Apple-Root-Zertifikaten (https://www.apple.com/certificateauthority/)
APPLE_ROOT_CA_DIR=""

# Google Play Developer API (Service-Account) + RTDN-Pub/Sub-Audience
GOOGLE_PLAY_PACKAGE_NAME="de.learnsphere.app"
GOOGLE_PLAY_SA_EMAIL=""
GOOGLE_PLAY_SA_PRIVATE_KEY=""
GOOGLE_RTDN_AUDIENCE=""

# --- OAuth-Login in der App (id_token-Exchange) ---
# erlaubte Client-IDs kommagetrennt (Web-, iOS-, Android-Client-ID)
GOOGLE_MOBILE_CLIENT_IDS=""
LINKEDIN_MOBILE_CLIENT_IDS=""
